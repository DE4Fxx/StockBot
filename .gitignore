*.key
*.pem
*.crt
*.p12
*.pfx
*.secret

# ========================
# NODE
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# LOGS & CACHE PERSISTENCE
# ========================
# Ignore runtime log/cache files, but FORCE track our code files
logs/
*.log
*.log.*
debug.log

# Force Git to track our structural cache configuration script
!cache/cache.js

# ========================
# BUILD OUTPUT
# ========================
dist/
build/
out/
coverage/

